n you checkout. Image shown below."}]},"referredUser":{"heading":"You Won","reward":"1 Scratch Card","info":"A friend has invited you to Myntra's End Of Reason Sale. Visit now & get a chance to win up to ₹150 MynCash!","claimCta":"CLAIM SCRATCH CARD","imageUrl":"https://constant.myntassets.com/pwa/assets/img/reward_half_card.png"},"limitErrorMsg":"You have reached the maximum reward limit of ₹500 using Shout & Earn"},"cardStore":{"cashInfo":"MynCash earned","heading":"Your Rewards","info":"Scratch the card to claim your rewards","cta":"INVITE FRIENDS","tncLink":"https://www.myntra.com/tac","moneyImage":"https://constant.myntassets.com/pwa/assets/img/money.png"},"scratchPopup":{"usJoinedMsg1":"You got this scratch card because","usJoinedMsg2":"invited you. Scratch & earn Myncash to get an additional discount from 9th to 16th Dec at the Myntra’s End Of Reason sale","usInviteMsg1":"You got this scratch card because","usInviteMsg2":"accepted your invitation. Scratch & earn Myncash to get an additional discount from 9th to 16th Dec at the Myntra’s End Of Reason sale","sMsg1":"You've earned ₹","sMsg2":"MynCash from this scratch card.\nUse this to get an additional discount from 9th to 16th Dec at the Myntra’s End Of Reason sale!","usHeading":"Win up to ₹150 MynCash!","moneyImage":"https://constant.myntassets.com/pwa/assets/img/money.png","cashInfo":"MynCash earned"},"noSale":{"image":"https://constant.myntassets.com/pwa/assets/img/announcement.png","message":"Sale Ended","description":"Shout & Earn program was only for Myntra's End Of Reason Sale. The sale has now ended. See you in the next one!","actionText":"CONTINUE SHOPPING","action":"/"},"fraudDetected":{"text":"No scratch card for you","actionText":"OKAY","fqa":[{"title":"Why didn't you get a scratch card?","description":"We were unable to give you a scratch card because we noticed some suspicious activity on your Myntra account"},{"title":"Want to know more about this?","description":"Please get in touch with our c