function EventBus() {
    this.listeners = {};
}

EventBus.prototype.addListener = function (eventName, callback, scope) {
    var newArgs = []
    for (var i = 3; i < arguments.length; i++) {
        newArgs.push(arguments[i])
    }
    if (typeof this.listeners[eventName] === "object") {
    this.listeners[eventName].push({
        scope: scope,
        callback: callback,
        args: newArgs
    });
    } else {
    this.listeners[eventName] = [
        {
        scope: scope,
        callback: callback,
        args: newArgs
        }
    ];
    }
}

EventBus.prototype.removeListener = function(eventName, callback, scope) {
    if (this.listeners[eventName] && this.listeners[eventName].length > 0) {
        var newListeners = []
        var oldListeners = this.listeners[eventName]
        for (var i=0; i < oldListeners.length; i++) {
            if (oldListeners[i].callback != callback || oldListeners[i].scope != scope) {
                newListeners.push(oldListeners[i])
            }
        }
        this.listeners[eventName] = newListeners
    }
}

EventBus.prototype.emit = function(eventName) {
    var newArgs = []
    for (var i = 1; i < arguments.length; i++) {
        newArgs.push(arguments[i])
    }
    if (this.listeners[eventName] && this.listeners[eventName].length > 0) {
    this.listeners[eventName].forEach(function(listener){
        listener.callback.apply(
        listener.scope,
        listener.args.concat(newArgs)
        );
    });
    }
}

SHELL.EventBus = new EventBus();

      var getElement = function(selector) { return document.querySelector(selector); }

var body = getElement("body")
var myMenu = getElement('.nav')
var appNav = getElement('.app-nav')
var hamburgerIcon = getElement('#header-menu-icon')

myMenu.addEventListener('transitionend', onTransitionEnd)
myMenu.addEventListener('click', hideMenu)
hamburgerIcon.addEventListener('click', showMenu)


function showMenu (e) {
  SHELL.EventBus.emit('menuIconClicked');
  myMenu.classList.add('nav--visible', 'nav--animatable')
  body.classList.add('no-scroll-background')
}

/**
 * hide menu if click is triggered on the last(deepest) item
 * or, on the overlay. Otherwise don't hide the menu.
 */
function hideMenu (e) {
  var menuClasses = myMenu.classList
  body.classList.remove('no-scroll-background')

  /**
   * If the click is triggered on the item, simple hide the nav bar
   * without any animations.
   * If the click is triggered on the overaly, hide nav with animations
   */

  if (!Element.prototype.matches) {
    Element.prototype.matches =
        Element.prototype.matchesSelector ||
        Element.prototype.mozMatchesSelector ||
        Element.prototype.msMatchesSelector ||
        Element.prototype.oMatchesSelector ||
        Element.prototype.webkitMatchesSelector;
  }

  if (e.target.matches('a.naviLevel') || e.target.matches('span.naviLevelNewTagRact')) {
    menuClasses.remove('nav--visible')
  } else if (e.target.matches('.nav.nav--visible')) {
    menuClasses.add('nav--animatable')
    menuClasses.remove('nav--visible')
  }
}

function onTransitionEnd () {
  myMenu.classList.remove('nav--animatable')
}

/**
 *
 * @param url => check if url is absolute url or not.
 */
function isAbsoluteUrl(url) {
 return (url.indexOf('http') === 0 || url.indexOf('www') === 0) ? true : false;
}

/**
 *
 * @param  url => Takes a url and returns a relative url if absolute url is found.
 */
function stripAbsoluteUrl(url) {
  if (!isAbsoluteUrl(url)) {
    return url;
  }
  var startPos = url.indexOf(".com");
  startPos = url.indexOf("/", startPos);
  var relUrl = url.slice(startPos);
  return relUrl;
}

/**
 * Check for special protocols like tel: and requests to other domains
 */
function outsideOurScope(url) {
  // 1. check if its for a different domain altogether
  // OR
  // 2. check if it has a different protocol
  var whitelist = MYNTRA && MYNTRA.myx && MYNTRA.myx.kvpairs && MYNTRA.myx.kvpairs["pwa.externalDomains"] || [];
  return whitelist.some(function(domain) {
    return url.indexOf(domain) !== -1;
  });
}

/**
 *
 * @param url => Redirect to a url. Supports both - client side as well as page refresh.
 */
function redirectTo (url, behaviour) {
  if (!url) {
    return;
  }

  if (outsideOurScope(url)) {
    window.location = url;
    return;
  }

  if (navigator.share && url.indexOf('/share') > -1) {
    return handleNativeShare();
  }

  url = stripAbsoluteUrl(url);
  var externalUrl = MYNTRA && MYNTRA.myx && MYNTRA.myx.android && MYNTRA.myx.android.urlByPasses || [];
  var externalPwaUrls = MYNTRA && MYNTRA.myx && MYNTRA.myx.kvpairs && MYNTRA.myx.kvpairs["pwa.routes.external"] || [];
  externalUrl = externalUrl.concat(externalPwaUrls);
  var redirectionPwaUrls = MYNTRA && MYNTRA.myx && MYNTRA.myx.kvpairs && MYNTRA.myx.kvpairs["pwa.routes.redirection"] || {};
  var appRoutes = MYNTRA && MYNTRA.myx && MYNTRA.myx.kvpairs && MYNTRA.myx.kvpairs["feed.appRoutes"] || [];
  var urlPathName = url.split("/")[1] || "";
  urlPathName = urlPathName.split("?")[0] || "";

  if (appRoutes.indexOf(urlPathName) >= 0) {
    window.rrhistory.push("/app-install-myntra");
    return;
  }

  // Check if the url starts with one of the external url pattern.
  var internalRoute = externalUrl.every(function(pattern) {
    if (pattern && pattern.length === 1) {
      return true;
    }
    return urlPathName !== pattern ? true : false;
  });

  if (internalRoute && window.rrhistory) {
    if (url === '/back' || behaviour === 'referrer') {
      window.rrhistory.goBack();
    } else if (behaviour === "replace") {
      window.rrhistory.replace(url);
    }
    else {
      window.rrhistory.push(url);
    }
  } else {
    if (url === '/back') window.history.back();
    var redirectionUrl = redirectionPwaUrls[url];
    if (redirectionUrl) {
      window.location.href = redirectionUrl;
    } else {
      window.location.href = url;
    }
  }
}


window.fbAsyncInit = function() {
  FB.init({
    appId            : '182424375109898',
    autoLogAppEvents : true,
    xfbml            : false,
    version          : 'v2.11',
    status           : true
  });
  FB.AppEvents.logPageView();
  FB.getLoginStatus(function(resp){
    window.MYNTRA.fbloginstatus=resp;
    SHELL.EventBus.emit("fbsdk-loaded");
  });
};
window.onGoogleYoloLoad = function(googleyolo) {
  window.googleyolo = googleyolo;
  SHELL.EventBus.emit("googleYoloLoaded");
};

function handleNativeShare () {
  var productTitleNode = document.getElementsByClassName('product-detail')[0];
  var productTitle = productTitleNode && productTitleNode.innerText;
  var productURL = window.location.protocol + "//" + window.location.hostname + window.location.pathname;
  window.ga("send", "event", "share_action", "button_click", productURL);

  navigator.share({
    title: productTitle,
    text: productTitle,
    url: productURL
  }).then(function() {
       window.ga("send", "event", "share_action", "share_success", productURL);
  }).catch(function (e) { console.log('Error in sharing', e)});
}

// event to handle all anchor tags
body.addEventListener('click', function (e) {
  try {
    for (var target=e.target; target && target !== this; target=target.parentNode) {
      if(target.getAttribute("data-stopeventpropagation") === "true") {
         break;
      }
      if (target.tagName.toLowerCase() === 'a' && typeof target.href === 'string') {
        const stop_redirection = target.getAttribute("data-stopredirection")
        const hydrationCompleted = window.hydrationCompleted;
        e.preventDefault();
        if(stop_redirection === 'true' && hydrationCompleted) break; // hydrationCompleted will be set true as soon as mobile.js is loaded
        setTimeout(function() { window.redirectTo(target.href); } , 0);
        break;
      }
    }
  } catch (e) {
    console.log('dom error', e);
  }
});



/**
 * Touch Event handling for Side bar navigation
 */

;(function() {
  var startX = 0;
  var distX = 0;
  var initialWidth = appNav.offsetWidth;
  var menuClasses =  myMenu.classList;
  var startY = 0;
  var distY = 0;
  var show = false;

  body.addEventListener('touchstart', onTouchStart, false);
  body.addEventListener('touchmove', onTouchMove, false);
  body.addEventListener('touchend', onTouchEnd, false);
  myMenu.addEventListener('touchstart', onTouchStart, false);
  myMenu.addEventListener('touchmove', onTouchMoveReverse, false);
  myMenu.addEventListener('touchend', onTouchEndReverse, false);

  function getClientX(e) {
    return parseInt(e.changedTouches[0].clientX);
  }

  function getClientY(e) {
    return parseInt(e.changedTouches[0].clientY);
  }

  function onTouchStart (e) {
    // e.preventDefault();
    startX = getClientX(e);
    startY = getClientY(e);

  }

  /**
   * Initial transform = translateX(-100%)
   * To show the navbar on the screen, translateX has to move gradually
   * toward 0.
   * When translateX becomes equal to 0, it means item is completly shown
   * on the screen.
   *
   * -100% is initail translateX -> hidden state
   * initialWidth is the width of the navbar, which is 300px at the time of
   * writing this code.
   *
   * Let's see how ((100/initialWidth) * distX) works:
   *    since initialWidth is 300px which is equalivalent to 100%
   *    so, 1px = (100/300)%
   *    Now, when you move your mouse, distX gives the number of pixels
   *    moved.
   *    So, ((100/initialWidth) * distX) gives me the amount we have moved the navbar
   *    in terms of percentage.
   *
   * Since -100% has to move toward 0% in order to show the navbar, we add our 'moved'
   * percentage to -100% to make sure we gradually show navbar on the screen as we move
   * our mouse/finger.
   *
   */
  function onTouchMove (e) {
    var swipeXtoBeIgnored = 10;
    distX = getClientX(e) - startX - swipeXtoBeIgnored;
    distY = getClientY(e) - startY;
    show = Math.abs(distX) > Math.abs(distY);

    if (show && startX < 20 && distX > 0 && distX <= initialWidth) {
      var percent = -100 + ((100/initialWidth) * distX);
      menuClasses.add('nav--visible');

      // Buffer for percentage!
      if (percent > -2 && percent <= 0) {
        appNav.removeAttribute('style');
      } else {
        appNav.style.transform = 'translateX('+ percent +'%)';
      }
    }
  }

  function onTouchEnd (e) {
    if (startX > 20) return;

    distX = getClientX(e) - startX;
    distY = getClientY(e) - startY;
    show = Math.abs(distX) > Math.abs(distY);
    appNav.removeAttribute('style');

    if (distX > (initialWidth / 4)) {
      if(show) {
        showMenu(e);
      }
    } else {
      menuClasses.add('nav--animatable');
      menuClasses.remove('nav--visible');
      hideMenu(e)
    }
  }

  function onTouchMoveReverse (e) {
    distX = startX - getClientX(e);
    if (distX > 0 && distX <= initialWidth) {
      var percent =  - ((100/initialWidth) * distX);

      // Buffer for percentage!
      if (percent < -98) {
        appNav.removeAttribute('style');
        menuClasses.add('nav--animatable');
        menuClasses.remove('nav--visible');
        hideMenu(e)
      } else {
        appNav.style.transform = 'translateX('+ percent +'%)';
      }
    }
  }

  function onTouchEndReverse (e) {
    distX = startX - getClientX(e);
    appNav.removeAttribute('style');

    if (distX > (initialWidth / 4)) {
      menuClasses.add('nav--animatable');
      menuClasses.remove('nav--visible');
      hideMenu(e)
    } else {
      showMenu(e);
    }
  }

}());

      window.ga=window.ga||function(){(ga.q=ga.q||[]).push(arguments)};ga.l=+new Date;
ga('create', 'UA-1752831-18', 'auto',{'useAmpClientId': true});
ga('set', 'dimension47', 'PWA');

(function () {
    var content = document.querySelector('body');
    content.addEventListener('click', function (event) {
        var type = event.target.type;
        var gaData = (event.target.dataset && event.target.dataset.ga) || event.target.innerText || event.target.id || (event.target.parentNode && event.target.parentNode.id) ||event.target.className;
        if ((type === 'button' || type === 'submit') && ga) {
            ga('send', 'event', 'button-click', gaData);
        }
        else if(event.target.dataset && event.target.dataset.ga){//any tag has data-ga attribute will be tracked on click.
            ga('send', 'event', 'click', event.target.dataset.ga);
        }
    });
    window.onerror = function (msg, url, lineNo, columnNo, error) {
        var string = msg.toLowerCase();
        var substring = "script error";
        if (string.indexOf(substring) > -1){
            console.log('Script Error');
        } else {
            var message = [
                'Message: ' + msg,
                'URL: ' + url,
                'Line: ' + lineNo,
                'Column: ' + columnNo,
                'Error object: ' + JSON.stringify(error)
            ].join(' - ');
            ga('send', 'event', 'Javascript-Error', message);
        }
        return false;
    };
})();</script> <script>
  document.addEventListener("click", e => {
    if (window.hydrationCompleted === true) return; 
    const scrollTarget = e.target.closest('[data-scroll-to]');
    if (scrollTarget) {
      const scrollTargetId = scrollTarget.getAttribute("data-scroll-to");
      const scrollTargetElem = document.getElementById(scrollTargetId);
      if (scrollTargetElem) {
        scrollTargetElem.scrollIntoView({
          behavior: 'smooth',
          block: 'center',
          inline: 'nearest'
        });
        return; // Add this return to prevent navigation code from running when scrollTo is triggered
      }
    }
    const target = e.target.closest('[data-href]');
    if (target) {
      const targetHref = target.getAttribute("data-href");
      if (targetHref) {
        window.location.href = targetHref;
      }
